<div
    class="form-group modifiable-value
    {{#if (hasModifierChanges data.changes)}}has-modifiers{{/if}}
    has-manual-input
    {{#if (includes @root.expandedPaths path)}}expanded{{else}}{{/if}}"
    data-path="{{path}}"
>
    <label data-tooltip="{{tooltip}}">{{localize label}}</label>

    <div class="form-fields">
        {{#if (hasModifierChanges data.changes)}}
        <span class="base-summary">
            <span class="summary-base">{{modifierBaseTotal data}}</span>
        </span>

        <span
            class="modifier-summary {{modifierSummaryClass data}}"
            data-tooltip="{{modifierSummaryTooltip data.changes}}"
        >
            <span class="summary-total">{{modifierNetTotal data}}</span>
            <span class="summary-count">{{modifierActiveCount data.changes}}/{{modifierCount data.changes}}</span>
        </span>
        {{/if}}

        <input type="number" name="{{path}}" value="{{data.value}}" size="3" maxlength="3" data-dtype="Number"/>
        <a class="toggle-breakdown" title="{{localize 'SR5.ToggleBreakdown'}}">
            <i class="fas fa-chevron-up"></i>
        </a>
    </div>

    <ol class="breakdown-list">
        {{#each data.changes as |change index|}}
        {{#unless (isBaseChange change)}}
        <li class="breakdown-entry {{getChangeCSS change}}" data-index="{{index}}">
            {{#if (getChangeEffectImage change)}}
            <button
                type="button"
                class="modifier-effect-button modifier-source-button has-effect"
                data-source="{{change.source}}"
                data-tooltip="{{localize 'SR5.Tooltips.Effect.EditEffect'}}"
                aria-label="{{localize 'SR5.Tooltips.Effect.EditEffect'}}"
            >
                {{#with (getChangeEffectImage change) as |effectImage|}}
                <img src="{{effectImage}}" alt="" />
                {{/with}}
            </button>
            {{else if change.source}}
            <button
                type="button"
                class="modifier-effect-button modifier-source-button has-effect"
                data-source="{{change.source}}"
                data-tooltip="SR5.OpenSource"
                aria-label="{{localize 'SR5.OpenSource'}}"
            >
                {{#if (isPDF change.source)}}
                <i class="fas fa-file-pdf"></i>
                {{else if (isURL change.source)}}
                <i class="fas fa-link"></i>
                {{else if (isUuid change.source)}}
                <i class="fas fa-file"></i>
                {{else}}
                <i class="fas fa-question"></i>
                {{/if}}
            </button>
            {{else}}
            <button
                type="button"
                class="modifier-effect-button no-effect disabled"
                disabled
            >
            </button>
            {{/if}}
            <span class="mod-name" data-tooltip="{{getChangeDescription change}}">{{localize change.name}}</span>
            {{#if (isManualChange change)}}
            <input
                type="number"
                class="modifier-value-input"
                name="{{../path}}.changes.{{index}}.value"
                value="{{change.value}}"
                data-dtype="Number"
            />
            {{else}}
            <span class="modifier-value-input">{{getChangeValue change}}</span>
            {{/if}}

            <input type="checkbox" name="{{../path}}.changes.{{index}}.enabled" data-dtype="Boolean" {{checked change.enabled}} />
        </li>
        {{/unless}}
        {{/each}}

        <li class="breakdown-entry manual-modifier-entry" data-path="{{path}}">
            <button
                type="button"
                class="modifier-effect-button no-effect disabled"
                disabled
            >
            </button>
            <input
                type="text"
                class="manual-modifier-name"
                placeholder="{{localize 'SR5.ManualModifier'}}"
                aria-label="{{localize 'SR5.ManualModifier'}}"
            />
            <input
                type="number"
                class="manual-modifier-value"
                placeholder="0"
                aria-label="{{localize 'SR5.ManualModifierValue'}}"
            />
            <button
                type="button"
                class="manual-modifier-create"
                data-tooltip="SR5.Add"
                aria-label="{{localize 'SR5.Add'}}"
            >
                <i class="fas fa-plus"></i>
            </button>
        </li>
    </ol>
</div>
