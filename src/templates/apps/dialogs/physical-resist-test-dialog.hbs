<form>
    <div class="dialog-content-common">
        {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-documents.hbs'}}
        <hr/>
        <div>
            <div class="form-group">
                <label>{{localize 'SR5.IncomingDamage'}}</label>
                <input type="number" value="{{test.data.incomingDamage.value}}" name="test.data.incomingDamage"/>
            </div>
            <div class="form-group">
                <label>{{localize 'SR5.DamageType'}}</label>
                <select name="test.data.incomingDamage.type.value">
                    {{selectOptions config.damageTypes selected=test.data.incomingDamage.type.value localize=true}}
                </select>
            </div>
            <div class="form-group">
                <label>{{localize 'SR5.AP'}}</label>
                <input type="number" value="{{test.data.incomingDamage.ap.value}}" name="test.data.incomingDamage.ap" data-dtype="Number"/>
            </div>
            <div class="form-group">
                <label>{{localize 'SR5.Element'}}</label>
                <select name="test.data.incomingDamage.element.value">
                    {{selectOptions config.elementTypes selected=test.data.incomingDamage.element.value localize=true blank='SR5.None'}}
                </select>
            </div>
        </div>
    </div>
    <div>
        {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-common.hbs'}}
    </div>
</form>