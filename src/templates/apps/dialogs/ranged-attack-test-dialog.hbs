<form>
    <div class="dialog-content-common">
        {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-documents.hbs'}}
        <hr/>
        <div>
            <div class="form-group">
                <label>{{localize "TYPES.Item.ammo"}}</label>
                <input type="text" class="disabled-for-display" disabled
                    value="{{test.item.system.ammo.current.value}}/{{test.item.system.ammo.current.max}}"/>
            </div>
            <div class="form-group">
                <label data-tooltip="SR5.Tooltips.RangedAttack.Recoil">
                    {{localize 'SR5.Recoil'}}
                    <span data-tooltip="SR5.Tooltips.RangedAttack.RecoilCompensation" style="font-weight: normal;"> (RC {{test.item.totalRecoilCompensation}})</span>
                </label>
                <div class="form-group-element-2">
                    <span data-tooltip="SR5.Tooltips.RangedAttack.RecoilBeforeAttack">{{test.recoilBeforeAttack}}</span>
                    <span data-tooltip="SR5.Tooltips.RangedAttack.RecoilAfterAttack">→ {{test.recoilAfterAttack}}</span>
                </div>
                <div id="reset-progressive-recoil" class="form-group-element-1-right roll" data-tooltip="SR5.Tooltips.RangedAttack.ResetRecoil"><button type="button">↺</button></div>
            </div>
            <div class="form-group">
                <label>{{localize 'SR5.FireMode'}}</label>
                <select name="test.data.fireModeSelected">
                    {{#select test.data.fireModeSelected}}
                    {{#each test.data.fireModes}}
                    <option value="{{@index}}">
                        {{localize this.label}} ({{this.value}}) ({{localize (objValue ../config.actionTypes this.action)}})
                    </option>
                    {{/each}}
                    {{/select}}
                </select>
            </div>
            {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/attack-range-dialog-fragment.hbs'}}
        </div>
        <div>
            {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-common.hbs'}}
        </div>
    </div>
</form>