<form>
    <div class="dialog-content-common">
        {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-documents.hbs'}}
        <hr/>
        <div>
            {{#if test.data.marks}}
            <div class="form-group matrix-marks-icon-row">
                <label>{{localize "SR5.Marks"}}</label>
                <div class="matrix-marks-icon-group" role="radiogroup" aria-label="{{localize 'SR5.Marks'}}">
                    <label class="matrix-marks-icon-option">
                        <input class="matrix-marks-icon-input" type="radio" name="test.data.marks" value="1" data-dtype="Number" {{#if (eq test.data.marks 1)}}checked{{/if}}/>
                        <span class="matrix-marks-icon-face">
                            <i class="fa-solid fa-1"></i>
                        </span>
                    </label>
                    <label class="matrix-marks-icon-option">
                        <input class="matrix-marks-icon-input" type="radio" name="test.data.marks" value="2" data-dtype="Number" {{#if (eq test.data.marks 2)}}checked{{/if}}/>
                        <span class="matrix-marks-icon-face">
                            <i class="fa-solid fa-2"></i>
                        </span>
                    </label>
                    <label class="matrix-marks-icon-option">
                        <input class="matrix-marks-icon-input" type="radio" name="test.data.marks" value="3" data-dtype="Number" {{#if (eq test.data.marks 3)}}checked{{/if}}/>
                        <span class="matrix-marks-icon-face">
                            <i class="fa-solid fa-3"></i>
                        </span>
                    </label>
                </div>
            </div>
            {{/if}}
            <div class="form-group">
                <label>{{localize "SR5.SameGrid"}}</label>
                <input type="checkbox" class="checkbox" name="test.data.sameGrid" {{checked test.data.sameGrid}} {{#if test.data.sameGridDisabled}}disabled data-tooltip="SR5.Tooltips.MatrixTest.SameGridDisabled"{{/if}}/>
            </div>
            <div class="form-group">
                <label>{{localize "SR5.DirectConnection"}}</label>
                <input type="checkbox" class="checkbox" name="test.data.directConnection" {{checked test.data.directConnection}}/>
            </div>
            {{#if test.controller}}
            <div class="document">
                <img src="{{test.controller.img}}"/>
                {{test.controller.name}}
            </div>
            {{/if}}
            <div class="form-group">
                <label>{{localize "SR5.Labels.Matrix.TargetMainIcon"}}</label>
                <input type="checkbox" class="checkbox" name="test.data.targetMainIcon" {{checked test.data.targetMainIcon}}/>
            </div>
            {{#if test.persona}}
            <!-- Persona targeted -->
            <div class="form-group">
                <label>{{localize "SR5.Target"}}</label>
                <div>{{speakerName test.persona}}</div>
            </div>
            {{/if}}
            {{#if test.host}}
            <div class="form-group">
                <label>{{localize "TYPES.Item.host"}}</label>
                <div>{{test.host.name}}</div>
            </div>
            {{/if}}
            {{#if test.grid}}
            <div class="form-group">
                <label>{{localize "TYPES.Item.grid"}}</label>
                <div>{{test.grid.name}}</div>
            </div>
            {{/if}}
            <!-- Devices connected to persona or host -->
            {{#ife test.data.targetMainIcon false}}
            <div class="form-group">
                <label>{{localize "SR5.Labels.Matrix.TargetDevice"}}</label>
                <select name="test.data.iconUuid" class="display">
                    {{selectOptions test.iconOptions selected=test.data.iconUuid}}
                </select>
            </div>
            {{/ife}}
        </div>
        <div>
            {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-common.hbs'}}
        </div>
    </div>
</form>
