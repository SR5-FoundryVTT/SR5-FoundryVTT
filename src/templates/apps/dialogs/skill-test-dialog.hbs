<form>
    <div class="dialog-content-common">
        {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-documents.hbs'}}
        <hr/>
        <div>
            <div class="form-group">
                <label>{{localize "SR5.Attribute"}}</label>
                <select name="test.data.attribute">
                    {{selectOptions config.attributes selected=test.data.attribute localize=true sort=true blank=''}}
                </select>
            </div>
            <div class="form-group">
                <label>{{localize "SR5.Limit"}}</label>
                <select name="test.data.limitSelection">
                    {{selectOptions config.limits selected=test.data.limitSelection localize=true sort=true blank=''}}
                </select>
            </div>
        </div>
    </div>
    <div>
        {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-common.hbs'}}
    </div>
</form>