<div class="extended-test-config-form">
    <div class="form-group">
        <label>{{localize "SR5.ExtendedTestManager.Name"}}</label>
        <input type="text" name="name" value="{{record.name}}" required/>
    </div>

    <div class="form-group">
        <label>{{localize "SR5.ExtendedTestManager.Description"}}</label>
        <textarea name="description" rows="2">{{record.description}}</textarea>
    </div>

    <div class="form-group">
        <label>{{localize "SR5.ExtendedTestManager.Notes"}}</label>
        <textarea name="notes" rows="2">{{record.notes}}</textarea>
    </div>

    <div class="form-group">
        <label>{{localize "SR5.ExtendedTestManager.Actor"}}</label>
        <select name="actorUuid">
            <option value="">{{localize "SR5.ExtendedTestManager.NoActor"}}</option>
            {{#each actorOptions}}
            <option value="{{this.uuid}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
            {{/each}}
        </select>
    </div>

    <div class="form-group etm-config-values">
        <label>{{localize "SR5.DicePool"}}</label>
        <input type="number" name="dicePool" value="{{record.dicePool}}" min="0" step="1"/>
        <label>{{localize "SR5.Threshold"}}</label>
        <input type="number" name="threshold" value="{{record.threshold}}" min="0" step="1"/>
    </div>

    <div class="form-group">
        <label>{{localize "SR5.ExtendedTestManager.Interval"}}</label>
        <div class="duration-control-fields duration-value-fields">
            <input type="number" name="interval.value" value="{{record.interval.value}}" min="0" step="1"/>
            <select name="interval.unit" data-dtype="String">
                {{#each intervalUnits}}
                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
            </select>
        </div>
    </div>

    <div class="form-group toggle-checkbox-row">
        <label data-tooltip="SR5.ExtendedTestManager.CumulativeModifierTooltip">{{localize "SR5.ExtendedTestManager.CumulativeModifier"}}</label>
        <input type="checkbox" name="cumulativeModifier" {{#if record.cumulativeModifier}}checked{{/if}}/>
    </div>

    <div class="form-group toggle-checkbox-row">
        <label data-tooltip="SR5.ExtendedTestManager.AdvanceTimeTooltip">{{localize "SR5.ExtendedTestManager.AdvanceTime"}}</label>
        <input type="checkbox" name="advanceTimeOnRoll" {{#if record.advanceTimeOnRoll}}checked{{/if}}/>
    </div>

    <div class="form-group">
        <label>{{localize "SR5.ExtendedTestManager.Filters.Visibility"}}</label>
        <select name="visibility">
            {{#each visibilityOptions}}
            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
        </select>
    </div>

    {{#if userOptions.length}}
    <fieldset class="etm-config-users">
        <legend>{{localize "SR5.ExtendedTestManager.UserPermissions"}}</legend>
        <table>
            <thead>
                <tr>
                    <th>{{localize "SR5.ExtendedTestManager.User"}}</th>
                    <th>{{localize "SR5.ExtendedTestManager.CanView"}}</th>
                    <th>{{localize "SR5.ExtendedTestManager.CanEdit"}}</th>
                    <th>{{localize "SR5.ExtendedTestManager.CanRoll"}}</th>
                </tr>
            </thead>
            <tbody>
                {{#each userOptions}}
                <tr>
                    <td>{{this.name}}</td>
                    <td><input type="checkbox" name="visibleUsers.{{this.id}}" {{#if this.visible}}checked{{/if}}/></td>
                    <td><input type="checkbox" name="editUsers.{{this.id}}" {{#if this.edit}}checked{{/if}}/></td>
                    <td><input type="checkbox" name="rollUsers.{{this.id}}" {{#if this.roll}}checked{{/if}}/></td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        <p class="hint">{{localize "SR5.ExtendedTestManager.UserPermissionsHint"}}</p>
    </fieldset>
    {{/if}}

    <footer class="etm-config-footer">
        <button type="submit">
            <i class="fas fa-save"></i>
            {{#if isCreate}}{{localize "SR5.ExtendedTestManager.CreateTest"}}{{else}}{{localize "SR5.ExtendedTestManager.SaveTest"}}{{/if}}
        </button>
        <button type="button" data-action="cancel">
            <i class="fas fa-times"></i>
            {{localize "SR5.Dialogs.Common.Cancel"}}
        </button>
    </footer>
</div>
