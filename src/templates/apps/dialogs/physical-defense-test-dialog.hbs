<form>
    <div class="dialog-content-common">
        {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-documents.hbs'}}
        <hr/>
        <div>
            <div class="form-group">
                <label>{{localize 'SR5.Cover'}}</label>
                <select name="test.data.cover" data-dtype="Number">
                    {{selectOptions test.coverOptions selected=test.data.cover}}
                </select>
            </div>
            <div class="form-group">
                <label>{{localize 'SR5.ActiveDefense'}}</label>
                <select name="test.data.activeDefense">
                    {{selectOptions test.activeDefenseOptions selected=test.data.activeDefense blank='SR5.None' localize=true}}
                </select>
            </div>
        </div>
    </div>
    <div>
        {{> 'systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-common.hbs'}}
    </div>
</form>