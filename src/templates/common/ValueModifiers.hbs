<div class="value-modifiers-container {{#if card}}card-style{{/if}}">
    <div class="value-modifiers">
        {{#if (or (not card) value.base)}}
            <div class="value-modifier-name">{{localize 'SR5.BaseValue'}}</div>
            <div class="value-modifiers-base">{{value.base}}</div>
        {{/if}}
        {{#each value.changes as |change|}}
            {{#if change.enabled}}
                <div class="value-modifier-name {{getChangeCSS change}} {{#if change.invalidated}}value-modifiers-invalid-total{{/if}}">{{localize change.name}}</div>
                <div class="value-modifiers-modifier {{getChangeCSS change}} {{#if change.invalidated}}value-modifiers-invalid-total{{/if}}">{{getChangeValue change}}</div>
            {{/if}}
        {{/each}}
    </div>
</div>
