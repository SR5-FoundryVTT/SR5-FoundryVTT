<div class="list-item list-item-header">
    <div class="list-item-start skinny">
        <label>{{localize "SR5.Labels.Item.Properties"}}</label>
    </div>
</div>

<div class="list-item">
    <div class="list-item-start skinny">
        <label>{{localize "SR5.Rating"}}</label>
    </div>
    <div class="list-item-col paired-fields">
        {{formInput systemFields.technology.fields.rating value=source.system.technology.rating
                    max=(ift source.system.technology.max_rating source.system.technology.max_rating)
                    classes="short paired-field" rootId=rootId disabled=@root.isPlayMode}}
        <label class="paired-separator">/</label>
        {{formInput systemFields.technology.fields.max_rating value=source.system.technology.max_rating
                    classes="short paired-field" rootId=rootId disabled=@root.isPlayMode}}
    </div>
</div>

<div class="list-item">
    <div class="list-item-start skinny">
        <label data-tooltip="{{systemFields.technology.fields.conceal.fields.base.label}}">{{localize "SR5.Conceal"}}</label>
    </div>
    <div class="list-item-col">
        {{#if @root.isEditMode}}
            {{formInput systemFields.technology.fields.conceal.fields.base value=source.system.technology.conceal.base
                        classes="short" rootId=@root.rootId disabled=@root.isPlayMode}}
        {{else}}
            {{formInput systemFields.technology.fields.conceal.fields.base value=system.technology.conceal.value
                        classes="short" rootId=@root.rootId disabled=true}}
        {{/if}}
    </div>
</div>
