<div class="list-item list-item-header">
    <div class="list-item-start skinny">
        <label>{{localize (objValue @root.config.itemTypes item.type)}}</label>
    </div>
</div>

<div class="list-item">
    <div class="list-item-start skinny">
        <label data-tooltip="{{systemFields.target.hint}}">{{systemFields.target.label}}</label>
    </div>
    <div class="list-item-col">
        {{formInput systemFields.target value=source.system.target localize=true
                    classes="short" rootId=@root.rootId disabled=@root.isPlayMode}}
    </div>
</div>
<div class="list-item">
    <div class="list-item-start skinny">
        <label data-tooltip="{{systemFields.duration.hint}}">{{systemFields.duration.label}}</label>
    </div>
    <div class="list-item-col">
        {{formInput systemFields.duration value=source.system.duration localize=true
                    classes="short" rootId=@root.rootId disabled=@root.isPlayMode}}
    </div>
</div>
<div class="list-item">
    <div class="list-item-start skinny">
        <label data-tooltip="{{systemFields.fade.hint}}">{{systemFields.fade.label}}</label>
    </div>
    <div class="list-item-col">
        {{formInput systemFields.fade value=source.system.fade classes="short" rootId=@root.rootId disabled=@root.isPlayMode}}
    </div>
</div>
