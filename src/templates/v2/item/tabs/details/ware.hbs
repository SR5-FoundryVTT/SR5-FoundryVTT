<div class="list-item list-item-header">
    <div class="list-item-start skinny">
        <label>{{localize (objValue @root.config.itemTypes item.type)}}</label>
    </div>
</div>

{{#if @root.isEditMode}}
    <div class="list-item">
        <div class="list-item-start skinny">
            <label data-tooltip="SR5.Tooltips.Item.CostAdjustment">{{localize "SR5.Labels.Item.CostAdjustment"}}</label>
        </div>
        <div class="list-item-col">
            {{formInput systemFields.technology.fields.calculated.fields.cost.fields.adjusted
                        value=source.system.technology.calculated.cost.adjusted classes="short"
                        rootId=@root.rootId disabled=@root.isPlayMode}}
        </div>
    </div>
    <div class="list-item">
        <div class="list-item-start skinny">
            <label data-tooltip="SR5.Tooltips.Item.AvailabilityAdjustment">{{localize "SR5.Labels.Item.AvailabilityAdjustment"}}</label>
        </div>
        <div class="list-item-col">
            {{formInput systemFields.technology.fields.calculated.fields.availability.fields.adjusted
                        value=source.system.technology.calculated.availability.adjusted classes="short"
                        rootId=@root.rootId disabled=@root.isPlayMode}}
        </div>
    </div>
{{/if}}

<div class="list-item">
    <div class="list-item-start skinny">
        <label>{{localize "SR5.Rating"}}</label>
    </div>
    <div class="list-item-col">
        {{#if @root.isEditMode}}
            {{formInput systemFields.technology.fields.rating value=source.system.technology.rating
                        classes="short" rootId=rootId disabled=@root.isPlayMode}}
        {{else if system.technology.rating}}
            <label>{{system.technology.rating}}</label>
        {{/if}}
    </div>
</div>

<div class="list-item">
    <div class="list-item-start skinny">
        <label data-tooltip="{{systemFields.grade.hint}}">{{systemFields.grade.label}}</label>
    </div>
    <div class="list-item-col">
        {{#if @root.isEditMode}}
            {{formInput systemFields.grade value=source.system.grade localize=true
                        classes="short thicc" rootId=@root.rootId disabled=@root.isPlayMode}}
        {{else if system.grade}}
            <label>{{localizeOb system.grade @root.config.cyberwareGrades}}</label>
        {{/if}}
    </div>
</div>

<div class="list-item">
    <div class="list-item-start skinny">
        <label data-tooltip="SR5.EssenceCost">{{localize "SR5.EssenceCost"}}</label>
    </div>
    <div class="list-item-col">
        {{#if @root.isEditMode}}
            {{formInput systemFields.essence value=source.system.essence classes="short"
                        rootId=@root.rootId disabled=@root.isPlayMode}}
        {{else if system.technology.calculated.essence.value}}
            <label>{{floatValue system.technology.calculated.essence.value 2}}</label>
        {{/if}}
    </div>
</div>

<div class="list-item">
    <div class="list-item-start skinny">
        <label data-tooltip="{{systemFields.technology.fields.conceal.fields.base.label}}">{{localize "SR5.Conceal"}}</label>
    </div>
    <div class="list-item-col">
        {{#if @root.isEditMode}}
            {{formInput systemFields.technology.fields.conceal.fields.base value=source.system.technology.conceal.base
                        classes="short" rootId=@root.rootId disabled=@root.isPlayMode}}
        {{else}}
            <label>{{numberFormat system.technology.conceal.value sign=true}}</label>
        {{/if}}
    </div>
</div>
