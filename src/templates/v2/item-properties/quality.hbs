{{#unless (empty system.type)}}
    <label>{{localizeOb system.type @root.config.qualityTypes}}</label>
{{/unless}}
{{#if item.system.rating}}
    <label>{{localize "SR5.Rating"}}&nbsp;{{item.system.rating}}</label>
{{/if}}
{{#if item.system.karma}}
    <label>{{localize "SR5.Karma"}}&nbsp;{{item.system.karma}}</label>
{{/if}}
