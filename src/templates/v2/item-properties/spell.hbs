{{#unless (empty item.system.category)}}
    <label>{{localizeOb item.system.category @root.config.spellCategories}}</label>
{{/unless}}
{{#if (eq item.system.category 'combat')}}
    {{#unless (empty item.system.combat.type)}}
        <label>{{localizeOb item.system.combat.type @root.config.combatSpellTypes}}</label>
    {{/unless}}
{{else if (eq item.system.category 'illusion')}}
    {{#unless (empty item.system.illusion.type)}}
        <label>{{localizeOb item.system.illusion.type @root.config.illusionSpellTypes}}</label>
    {{/unless}}
    {{#unless (empty item.system.illusion.sense)}}
        <label>{{localizeOb item.system.illusion.sense @root.config.illusionSpellSense}}</label>
    {{/unless}}
{{else if (eq item.system.category 'manipulation')}}
    {{#if item.system.manipulation.damaging}}
        <label>{{localize "SR5.Spell.ManipulationDamaging"}}</label>
    {{/if}}
    {{#if item.system.manipulation.mental}}
        <label>{{localize "SR5.Spell.ManipulationMental"}}</label>
    {{/if}}
    {{#if item.system.manipulation.environmental}}
        <label>{{localize "SR5.Spell.ManipulationEnviornmental"}}</label>
    {{/if}}
    {{#if item.system.manipulation.physical}}
        <label>{{localize "SR5.Spell.ManipulationPhysical"}}</label>
    {{/if}}
{{else if (eq item.system.category 'detection')}}
    {{#unless (empty item.system.detection.type)}}
        <label>{{localizeOb item.system.detection.type @root.config.detectionSpellTypes}}</label>
    {{/unless}}
    {{#if item.system.detection.passive}}
        <label>{{localize "SR5.Passive"}}</label>
    {{else}}
        <label>{{localize "SR5.Active"}}</label>
    {{/if}}
    {{#if item.system.detection.extended}}
        <label>{{localize "SR5.DetectionSpellExtended"}}</label>
    {{/if}}
{{/if}}
{{#if item.system.action.damage.element.value}}
    <label data-tooltip="{{localizeOb item.system.action.damage.element.value @root.config.elementTypes}}">
        <i class="{{elementIcon item.system.action.damage.element.value}}"></i>
        {{localizeOb item.system.action.damage.element.value @root.config.elementTypes}}
    </label>
{{/if}}
{{#unless (empty item.system.type)}}
    <label>{{localizeOb item.system.type @root.config.spellTypes}}</label>
{{/unless}}
{{#unless (empty item.system.range)}}
    <label>{{localizeOb item.system.range @root.config.spellRanges}}</label>
{{/unless}}
{{#unless (empty item.system.duration)}}
    <label>{{localizeOb item.system.duration @root.config.durations}}</label>
{{/unless}}
<label>{{localize "SR5.Drain"}}&nbsp;{{localize "SR5.Force"}}{{#if item.system.drain}}{{numberFormat item.system.drain sign=true}}{{/if}}</label>
