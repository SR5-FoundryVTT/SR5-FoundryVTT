{{#if (eq item.system.actor_type 'sprite')}}
    <label>{{localize 'SR5.Compilation.SpriteType'}}&nbsp;{{item.system.sprite.type}}</label>
    <label>{{localize 'SR5.Level'}}&nbsp;{{item.system.sprite.level}}</label>
{{else if (eq item.system.actor_type 'spirit')}}
    <label>{{localize 'SR5.SpiritType'}}&nbsp;{{item.system.spirit.type}}</label>
    <label>{{localize 'SR5.Force'}}&nbsp;{{item.system.spirit.force}}</label>
{{/if}}
