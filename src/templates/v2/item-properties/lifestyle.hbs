{{#unless (empty item.system.type)}}
    <label>{{localizeOb item.system.type @root.config.lifestyleTypes}}</label>
{{/unless}}
{{#unless (empty item.system.neighborhood)}}
    <label><i data-tooltip="{{localize "SR5.LifestyleNeighborhood"}}" class="fas fa-buildings"></i>&nbsp;{{item.system.neighborhood}}</label>
{{/unless}}
{{#unless (empty item.system.comforts)}}
    <label><i data-tooltip="{{localize "SR5.LifestyleComforts"}}" class="far fa-mattress-pillow"></i>&nbsp;{{item.system.comforts}}</label>
{{/unless}}
{{#unless (empty item.system.security)}}
    <label><i data-tooltip="{{localize "SR5.LifestyleSecurity"}}" class="far fa-shield-halved"></i>&nbsp;{{item.system.security}}</label>
{{/unless}}
{{#unless (empty item.system.guests)}}
    <label><i data-tooltip="{{localize "SR5.LifestyleGuests"}}" class="far fa-people"></i>&nbsp;{{item.system.guests}}</label>
{{/unless}}
