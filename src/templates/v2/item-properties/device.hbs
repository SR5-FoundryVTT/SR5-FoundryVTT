{{#unless (empty item.system.category)}}
    <label>{{localizeOb item.system.category @root.config.deviceCategories}}</label>
{{/unless}}
{{#each item.system.atts}}
    {{#if this.value}}
        <label>{{localizeOb this.att @root.config.matrixAttributes}}&nbsp;{{this.value}}</label>
    {{/if}}
{{/each}}
