<div class="attribute{{#if cssClass}} {{cssClass}}{{/if}}" data-attribute-id="{{attributeField.name}}" data-context-menu="attribute">
    <label {{#if @root.isEditMode}}class="edit-mode"{{/if}}>
        {{#if label}}
            {{localize label}}
        {{else}}
            {{localize attribute.label}}
        {{/if}}
    </label>
    <div class="attribute-value">
        {{#if @root.isEditMode}}
            {{#if @root.isSpirit}}
                {{#ifne attributeField.name 'force'}}
                    <button type="button"
                            class="attribute-button force-apply-toggle{{#unless (objValue @root.system.force_applies attributeField.name)}} downlight{{/unless}}"
                            data-action="toggleSpiritForceAttribute"
                            data-attribute-id="{{attributeField.name}}"
                            data-tooltip="SR5.Spirit.ForceAppliesSettingHint">F +</button>
                {{/ifne}}
            {{/if}}
            {{formInput attributeField.fields.base value=attribute.base
                        classes="short skinny center" rootId=rootId }}
        {{else}}
            <button class="icon sr5-icon" type="button"
                    data-action="rollAttribute"
                    data-attribute-modifier-tooltip="{{attributeField.name}}">{{attribute.value}}</button>
        {{/if}}
    </div>
</div>
